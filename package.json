{
  "name": "testmu-ai-sdet",
  "version": "1.0.0",
  "description": "AI-augmented regression testing: LLM test generation + agentic Failure Explainer + Flaky Test Classifier, built on Playwright + TypeScript.",
  "type": "module",
  "engines": { "node": ">=18" },
  "scripts": {
    "test": "playwright test",
    "test:login": "playwright test tests/login.spec.ts",
    "test:dashboard": "playwright test tests/dashboard.spec.ts",
    "test:api": "playwright test tests/api.spec.ts",
    "report": "playwright show-report",
    "ai:generate": "tsx scripts/ai-generate.ts",
    "ai:flaky": "tsx scripts/flaky-report.ts",
    "install:browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "dotenv": "^16.4.5"
  }
}

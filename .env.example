# ---------------------------------------------------------------------------
# LLM provider (Anthropic). Leave ANTHROPIC_API_KEY blank to run the entire
# framework in deterministic MOCK mode — every AI feature still produces
# useful output, so `npm test` and CI go green with zero credentials.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Any Anthropic model id you have access to (this is just an example default).
AI_MODEL=claude-3-5-haiku-latest

# mock | live | auto  (auto = live if a key is present, otherwise mock)
AI_MODE=auto

# ---------------------------------------------------------------------------
# Targets under test (public demo apps; override to point at your own env)
# ---------------------------------------------------------------------------
SAUCE_BASE_URL=https://www.saucedemo.com
API_BASE_URL=https://restful-booker.herokuapp.com

# Set to 1 to enable the intentionally-flaky demo test that exercises the
# Failure Explainer + Flaky Classifier live. Off by default so CI stays green.
DEMO_FLAKY=
